{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "custom-variant",
          "theme",
          "tailwind",
          "apply",
          "variants",
          "screen",
          "layer",
          "import"
        ]
      }
    ]
  }
}
