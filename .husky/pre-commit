# Save the list of files that were originally staged
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Format code with Prettier
echo "🎨 Running Prettier to format code..."
npm run format

# Re-add only the files that were originally staged (now with formatting changes)
# This preserves the user's original selection of files to commit
if [ -n "$STAGED_FILES" ]; then
	echo "$STAGED_FILES" | xargs git add
fi

# Run ESLint to check for errors
echo "🔍 Running ESLint to check for errors..."
npm run lint

# If ESLint fails, the commit will be blocked
if [ $? -ne 0 ]; then
  echo "❌ ESLint found errors. Please fix them before committing."
  exit 1
fi

# Run tests
echo "🧪 Running tests..."
npm run test:ci

# If tests fail, the commit will be blocked
if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Please fix them before committing."
  exit 1
fi

echo "✅ All checks passed! Proceeding with commit..."
